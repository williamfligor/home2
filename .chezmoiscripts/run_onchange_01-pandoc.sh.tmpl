#!/bin/bash
# vi: ft=bash
set -euo pipefail
cinstall=~/.local/share/chezmoi/dot_local/bin/executable_cinstall

{{ $pandoc_url := dict
  "darwin-arm64" ( gitHubLatestReleaseAssetURL "jgm/pandoc" "pandoc-*-arm64-macOS.zip" )
  "linux-amd64" ( gitHubLatestReleaseAssetURL "jgm/pandoc" "pandoc-*-linux-amd64.tar.gz" )
  "linux-arm64" ( gitHubLatestReleaseAssetURL "jgm/pandoc" "pandoc-*-linux-arm64.tar.gz" )
}}
$cinstall \
    --url "{{ get $pandoc_url ( printf "%s-%s" .chezmoi.os .chezmoi.arch ) }}" \
    --cmd 'mv */bin/pandoc* ~/.local/bin/'
