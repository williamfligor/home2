theme = iTerm2 Solarized Light

# Font Settings
font-family = JetBrains Mono
font-size = 11

# Automagic for SSH TERM Handling
shell-integration-features = cursor,title,session,ssh-env,ssh-terminfo

# Fix oddly dark Vim line background color
palette = 7=#eee8d5

# Pane Navigation
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+h=goto_split:left
keybind = super+l=goto_split:right
keybind = super+backslash=new_split:right
keybind = super+shift+backslash=new_split:down
