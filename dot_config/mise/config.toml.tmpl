  version = "0.11.12",
  url = "https://github.com/jordanbaird/Ice/releases/download/0.11.12/Ice.zip",
}
"http:xbar" = {
  version = "2.1.7-beta",
  url = "https://github.com/matryer/xbar/releases/download/v2.1.7-beta/xbar.v2.1.7-beta.zip",
}

# .dmg disk images: mise downloads them;
# install-macos-apps mounts with hdiutil and installs the .app.
