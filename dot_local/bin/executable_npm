#!/bin/bash
# npm wrapper: prefer real npm if available, otherwise fallback to bun
# https://github.com/badlogic/pi-mono/discussions/1453#discussion-9454507

for dir in ${PATH//:/ } ; do
    candidate="$dir/npm"
    if [[ -x "$candidate" && "$candidate" != "$0" ]]; then
        exec "$candidate" "$@"
    fi
done

case "$1" in
    root)
        # Handle npm root -g command
        if [[ "$2" == "-g" ]]; then
            echo "$HOME/.cache/.bun/install/global/node_modules"
        else
            echo "node_modules"
        fi
        ;;
    *)
        # Forward all other commands to bun
        exec ~/.local/bin/bun "$@"
        ;;
esac
