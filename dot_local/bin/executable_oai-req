#!/usr/bin/env -S uv run --script
#
# /// script
# requires-python = ">=3.10"
# dependencies = ["requests"]
# ///
"""
oai-req — Make requests to OpenAI-compatible API endpoints.

Streams raw HTTP response to stdout for piping into oai-pretty or other tools.
Can also print the equivalent curl command for reproducibility.

Usage:
    oai-req --base https://api.openai.com/v1 --prompt "Hello" -- model=gpt-5 | oai-pretty
    oai-req --base https://api.openai.com/v1 --prompt "..." -- model=gpt-5 reasoning_effort=high | oai-pretty
    oai-req --base https://api.openai.com/v1 --prompt "Hi" -- model=gpt-5 --curl
    oai-req --base https://api.openai.com/v1 --prompt "Hi" -- model=gpt-5 reasoning_effort=high --dry-run

Environment variables (checked in order):
    OPENAI_API_KEY
    OPENROUTER_API_KEY
    OPENCODE_API_KEY
    API_KEY
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import textwrap

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

_COMMON_KEY_ENV_VARS = [
    "OPENAI_API_KEY",
    "OPENROUTER_API_KEY",
    "OPENCODE_API_KEY",
    "API_KEY",
]


def _die(msg: str, code: int = 1) -> None:
    print(f"oai-req: error: {msg}", file=sys.stderr)
    sys.exit(code)


def _resolve_key(explicit: str | None,
                 required: bool = True) -> str | None:
    """Resolve API key: explicit flag > common env vars > placeholder."""
    if explicit:
        return explicit
    for var in _COMMON_KEY_ENV_VARS:
        val = os.environ.get(var)
        if val:
            return val
    if required:
        _die(
            "API key not found. Set --api-key or one of: "
            + ", ".join(_COMMON_KEY_ENV_VARS)
        )
    return "$API_KEY"  # placeholder for --curl / --dry-run


# ---------------------------------------------------------------------------
# Prompt presets
# ---------------------------------------------------------------------------

