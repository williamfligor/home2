#!/usr/bin/env bash
# Create a new local ZMX session with a random name
# Changes to the last-known interactive cwd before launching
set -euo pipefail

cwd_file="${XDG_CACHE_HOME:-$HOME/.cache}/zmx-cwd"
if [[ -f "$cwd_file" ]]; then
  cd "$(<"$cwd_file")" 2>/dev/null || true
fi

session_name="zmx-$(date +%m%d-%H%M%S)"
exec zmx attach "$session_name"
