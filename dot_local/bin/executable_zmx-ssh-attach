#!/usr/bin/env bash
# autossh to host and attach to ZMX session (picker or named)
set -euo pipefail

host="${1:?Usage: zmx-ssh-attach <host> [session_name]}"
session_name="${2:-}"

ssh_opts=(
  -o ControlPersist=no
  -o ControlMaster=no
  -o ServerAliveInterval=15
  -o ServerAliveCountMax=3
  -o ExitOnForwardFailure=yes
)

if [[ -n "$session_name" ]]; then
  exec autossh -M 0 -q "${ssh_opts[@]}" -t -- "$host" zmx-local-attach "$session_name"
else
  exec autossh -M 0 -q "${ssh_opts[@]}" -t -- "$host" zmx-local-attach
fi
