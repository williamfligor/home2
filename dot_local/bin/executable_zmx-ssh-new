#!/usr/bin/env bash
# autossh to host and create a new ZMX session with random name
set -euo pipefail

host="${1:?Usage: zmx-ssh-new <host>}"

ssh_opts=(
  -o ControlPersist=no
  -o ControlMaster=no
  -o ServerAliveInterval=15
  -o ServerAliveCountMax=3
  -o ExitOnForwardFailure=yes
)

exec autossh -M 0 -q "${ssh_opts[@]}" -t -- "$host" zmx-local-new
