# vi: ft=zsh
# ------------------------ Early Config --------------------------------

setopt PROMPT_SUBST

# History config — 1 million entries in memory and saved to file
HISTFILE="${HISTFILE:-$HOME/.zsh_history}"
HISTSIZE=1000000
SAVEHISTORY=1000000

case "$TERM" in
    xterm-color|*-256color) color_prompt=yes;;
esac

# ------------------------ Powerlevel10k Instant Prompt --------------------------------
# Must stay close to the top of ~/.zshrc — initialization code that may require
# console input (password prompts, [y/n] confirmations, etc.) must go above this block.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ------------------------ Modular Config (zshrc.d) --------------------------------
# Source all .zsh files from ~/.zshrc.d/ in sorted order.
#  10-mise-plugin.zsh   — mise-plugin() function definition
#  90-history-backup.zsh — lazy zsh history backups
for __f in ~/.zshrc.d/*.zsh(N); do source "$__f"; done
unset __f

# ------------------------ Oh My Zsh + Plugins --------------------------------

export ZSH="$HOME/.local/share/mise/installs/http-oh-my-zsh/latest"

# Oh my zsh settings
ZSH_THEME=""
ENABLE_CORRECTION="true"

zstyle ':omz:update' mode disabled  # disable automatic updates

plugins=(git history-substring-search)

source $ZSH/oh-my-zsh.sh

# Source mise-managed zsh plugins (mise-plugin defined in 10-mise-plugin.zsh)
mise-plugin zsh-syntax-highlighting
mise-plugin vi-mode
# Fix: vi-mode binds ^j (LF/\n) to history-substring-search-down, but ^j IS
# the newline character. This breaks Orca's startup-command delivery (which
# sends \n to submit the command). Restore ^j to accept-line so Enter works.
bindkey -M viins '^j' accept-line
mise-plugin zsh-you-should-use
mise-plugin powerlevel10k powerlevel10k.zsh-theme

# Show current ZMX session in the right prompt
function prompt_my_zmx_session() {
  if [[ -n $ZMX_SESSION ]]; then
    p10k segment -b '%k' -f '%f' -t "[$ZMX_SESSION]"
  fi
}
POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS+=(my_zmx_session)

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

unsetopt correct_all

# ------------------------ Includes --------------------------------

{{ if eq .chezmoi.os "windows" -}}
export PATH=$PATH:/c/Program\ Files/Oracle/VirtualBox
{{ end -}}

{{ template "aliases.sh" . }}

{{ template "functions.sh" . }}

# Load ~/.local.sh if found
[[ ! -f ~/.local.sh ]] || source ~/.local.sh

# ------------------------ ZMX cwd tracking --------------------------------
# Save cwd on each prompt so zmx-local-new can start in the right directory
autoload -Uz add-zsh-hook
zmx-save-cwd() {
  printf '%s' "$PWD" >| "${XDG_CACHE_HOME:-$HOME/.cache}/zmx-cwd"
}
add-zsh-hook precmd zmx-save-cwd

# ------------------------ Key Bindings --------------------------------
bindkey -M vicmd '^[' undefined-key

# ------------------------ Other --------------------------------
# Set up fzf key bindings and fuzzy completion
if command -v fzf &> /dev/null; then
    source <(fzf --zsh)
fi
