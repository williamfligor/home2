{
  "defaultProvider": "opencode-go",
  "defaultModel": "deepseek-v4-flash",
  "theme": "light",
  "enableSkillCommands": true,
  "compaction": {
    "enabled": true,
    "reserveTokens": 19200,
    "keepRecentTokens": 19200
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "lastChangelogVersion": "1.0.0",
  "packages": [
    "npm:@ff-labs/pi-fff",
    "npm:pi-markdown-preview",
    "npm:pi-powerline-footer",
    "npm:pi-rewind",
    "npm:pi-smart-fetch",
    "npm:pi-subagents",
    "npm:pi-vim"
  ],
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "subagents": {
    "agentOverrides": {
      "context-builder": {},
      "planner": {},
      "researcher": {},
      "reviewer": {},
      "scout": {},
      "worker": {}
    }
  },
  "enabledModels": [
    "opencode-go/*",
    "llama-cpp/*"
  ],
  "powerline": {
    "preset": "default",
    "welcome": false,
    "mouseScroll": true,
    "layout": {
      "left": [
        "model",
        "thinking",
        "path",
        "context_pct",
        "cost",
        "git"
      ],
      "right": [],
      "secondary": [
        "extension_statuses"
      ]
    }
  }
}
