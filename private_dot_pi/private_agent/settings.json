{
  "defaultProvider": "llama-swap",
  "defaultModel": "qwen3.6-35b-a3b",
  "theme": "light",
  "enableSkillCommands": true,
  "npmCommand": [
    "bun"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 19200,
    "keepRecentTokens": 19200
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "lastChangelogVersion": "0.75.3",
  "packages": [
    {
      "source": "https://github.com/williamfligor/pi-duckfeed.git",
      "extensions": [
        "-find-extension.ts",
        "-open-extension.ts"
      ]
    },
    "npm:@ifi/oh-pi-prompts",
    "npm:pi-ask-user",
    "npm:pi-context",
    "npm:pi-markdown-preview",
    "npm:pi-rewind",
    "npm:pi-smart-fetch",
    "npm:pi-subagents",
    "npm:pi-vim"
  ],
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "subagents": {
    "agentOverrides": {
      "context-builder": {
        "model": "llama-swap/qwen3.6-35b-a3b"
      },
      "planner": {
        "model": "llama-swap/qwen3.6-35b-a3b",
        "thinking": "medium"
      },
      "researcher": {
        "model": "llama-swap/qwen3.6-35b-a3b"
      },
      "reviewer": {
        "model": "llama-swap/qwen3.6-35b-a3b",
        "thinking": "medium"
      },
      "scout": {
        "model": "llama-swap/qwen3.6-35b-a3b"
      },
      "worker": {
        "model": "llama-swap/qwen3.6-35b-a3b"
      }
    }
  }
}