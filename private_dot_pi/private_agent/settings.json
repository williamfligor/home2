{
  "defaultProvider": "opencode-go",
  "defaultModel": "deepseek-v4-flash",
  "theme": "light",
  "enableSkillCommands": true,
  "compaction": {
    "enabled": true,
    "reserveTokens": 19200,
    "keepRecentTokens": 19200
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "lastChangelogVersion": "0.79.9",
  "packages": [
    "https://github.com/williamfligor/pi-duckfeed.git",
    "npm:@ff-labs/pi-fff",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:cc-safety-net",
    "npm:pi-markdown-preview",
    "npm:pi-rewind",
    "npm:pi-subagents",
    "npm:pi-vim"
  ],
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": true,
  "subagents": {
    "agentOverrides": {
      "context-builder": {},
      "planner": {},
      "researcher": {},
      "reviewer": {},
      "scout": {},
      "worker": {}
    }
  },
  "enabledModels": [
    "opencode-go/*",
    "llama-cpp/*"
  ]
}